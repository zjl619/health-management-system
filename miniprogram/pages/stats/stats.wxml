<scroll-view class="scrollarea" scroll-y type="list">

  <!-- 健康评分 -->
  <view class="score-banner">
    <view class="score-circle">
      <text class="score-num">{{healthScore}}</text>
      <text class="score-label">健康分</text>
    </view>
    <view class="score-info">
      <text class="score-title">{{scoreTitle}}</text>
      <text class="score-sub">基于近7日打卡数据综合评估</text>
      <view class="score-bar-bg">
        <view class="score-bar-fill" style="width: {{healthScore}}%;"></view>
      </view>
    </view>
  </view>

  <!-- 成就徽章 -->
  <view class="section-card">
    <view class="section-title">🏅 打卡成就</view>
    <view class="badge-row">
      <view class="badge-item {{streak >= 3 ? 'unlocked' : 'locked'}}">
        <text class="badge-icon">🌱</text>
        <text class="badge-name">初出茅庐</text>
        <text class="badge-desc">连续3天</text>
      </view>
      <view class="badge-item {{streak >= 7 ? 'unlocked' : 'locked'}}">
        <text class="badge-icon">🔥</text>
        <text class="badge-name">一周坚持</text>
        <text class="badge-desc">连续7天</text>
      </view>
      <view class="badge-item {{streak >= 30 ? 'unlocked' : 'locked'}}">
        <text class="badge-icon">💪</text>
        <text class="badge-name">月度达人</text>
        <text class="badge-desc">连续30天</text>
      </view>
      <view class="badge-item {{totalDays >= 100 ? 'unlocked' : 'locked'}}">
        <text class="badge-icon">🏆</text>
        <text class="badge-name">百日健将</text>
        <text class="badge-desc">累计100天</text>
      </view>
    </view>
    <view class="streak-progress">
      <text class="streak-hint">当前连续 {{streak}} 天 · 下一成就还需 {{nextBadgeDiff}} 天</text>
    </view>
  </view>

  <!-- 近7日体温趋势 -->
  <view class="section-card" wx:if="{{tempChart.length > 0}}">
    <view class="section-title">🌡️ 近7日体温趋势</view>
    <view class="line-chart-wrap">
      <view class="line-y-labels">
        <text>38°</text><text>37.3°</text><text>37°</text><text>36.5°</text><text>36°</text>
      </view>
      <view class="line-chart">
        <view class="line-chart-bars">
          <view class="line-bar-item" wx:for="{{tempChart}}" wx:key="date">
            <view class="line-bar-bg">
              <view class="line-bar-fill {{item.isHigh ? 'danger' : 'safe'}}"
                style="height: {{item.heightPercent}};"></view>
              <view class="line-ref-line"></view>
            </view>
            <text class="line-bar-val">{{item.temp}}</text>
            <text class="line-bar-date">{{item.shortDate}}</text>
          </view>
        </view>
      </view>
    </view>
    <view class="chart-legend">
      <view class="legend-item"><view class="dot safe-dot"></view><text>正常</text></view>
      <view class="legend-item"><view class="dot danger-dot"></view><text>偏高 (>37.3°)</text></view>
    </view>
  </view>

  <!-- 运动/睡眠/饮水周均值 -->
  <view class="section-card" wx:if="{{weeklyStats.length > 0}}">
    <view class="section-title">📊 本周健康均值</view>
    <view class="avg-row">
      <view class="avg-card">
        <text class="avg-icon">🏃</text>
        <text class="avg-num">{{avgExercise}}</text>
        <text class="avg-unit">分钟/天</text>
        <text class="avg-label">运动时长</text>
        <view class="avg-bar-bg">
          <view class="avg-bar-fill blue" style="width: {{exercisePercent}}%;"></view>
        </view>
        <text class="avg-tip">{{avgExercise >= 30 ? '达标 ✓' : '建议≥30分钟'}}</text>
      </view>
      <view class="avg-card">
        <text class="avg-icon">😴</text>
        <text class="avg-num">{{avgSleep}}</text>
        <text class="avg-unit">小时/天</text>
        <text class="avg-label">睡眠时长</text>
        <view class="avg-bar-bg">
          <view class="avg-bar-fill purple" style="width: {{sleepPercent}}%;"></view>
        </view>
        <text class="avg-tip">{{avgSleep >= 7 ? '充足 ✓' : '睡眠不足'}}</text>
      </view>
      <view class="avg-card">
        <text class="avg-icon">💧</text>
        <text class="avg-num">{{avgWater}}</text>
        <text class="avg-unit">杯/天</text>
        <text class="avg-label">饮水量</text>
        <view class="avg-bar-bg">
          <view class="avg-bar-fill cyan" style="width: {{waterPercent}}%;"></view>
        </view>
        <text class="avg-tip">{{avgWater >= 8 ? '充足 ✓' : '建议≥8杯'}}</text>
      </view>
    </view>
  </view>

  <!-- 心情分布 -->
  <view class="section-card" wx:if="{{moodStats.length > 0}}">
    <view class="section-title">😊 近期心情分布</view>
    <view class="mood-stats-row">
      <view class="mood-stat-item" wx:for="{{moodStats}}" wx:key="mood">
        <text class="mood-big">{{item.mood}}</text>
        <view class="mood-count-bar-bg">
          <view class="mood-count-bar-fill" style="height: {{item.percent}}%;"></view>
        </view>
        <text class="mood-count-num">{{item.count}}</text>
      </view>
    </view>
  </view>

  <!-- 健康建议 -->
  <view class="section-card advice-card">
    <view class="section-title">💡 个性化建议</view>
    <view class="advice-item" wx:for="{{advices}}" wx:key="*this">
      <text class="advice-dot">•</text>
      <text class="advice-text">{{item}}</text>
    </view>
  </view>

  <view class="bottom-safe"></view>
</scroll-view>
