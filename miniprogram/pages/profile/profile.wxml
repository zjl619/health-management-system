<view class="page">
  <view class="card">
    <view class="title">个人资料</view>

    <view class="field">
      <text class="label">昵称</text>
      <input
        class="input"
        placeholder="请输入昵称"
        maxlength="20"
        value="{{nickname}}"
        bindinput="onNicknameInput"
      />
    </view>

    <view class="field">
      <text class="label">头像地址</text>
      <input
        class="input"
        placeholder="请输入头像 URL（可选）"
        value="{{avatar}}"
        bindinput="onAvatarInput"
      />
    </view>

    <view class="field">
      <text class="label">性别</text>
      <picker mode="selector" range="{{genderOptions}}" value="{{genderIndex}}" bindchange="onGenderChange">
        <view class="picker-value">{{genderOptions[genderIndex]}}</view>
      </picker>
    </view>

    <view class="actions">
      <button class="save-btn" loading="{{saving}}" bindtap="saveProfile">保存</button>
    </view>
  </view>
</view>
